    local f=Instance.new("Frame",SGui);f.Name=n;f.BackgroundColor3=Color3.new(0,0,0);f.BorderSizePixel=2;f.BorderColor3=Color3.fromRGB(60,60,60);f.Position=p;f.Size=UDim2.new(0,s.X.Offset,0,42);f.Active=true;f.Draggable=true;f.ClipsDescendants=true
    
