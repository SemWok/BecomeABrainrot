local function B_Toggle(p,t,func)
    local b=Instance.new("TextButton",p);b.Size=UDim2.new(1,0,0,40);b.Position=UDim2.new(0,0,0,#p:GetChildren()*40-40);b.BackgroundTransparency=1;b.RichText=true;b.Text="<b>  "..t.."</b>";b.TextColor3=Color3.fromRGB(255,255,255);b.Font=Enum.Font.SourceSansBold;b.TextSize=18;b.TextXAlignment=0
    local box=Instance.new("Frame",b);box.Size=UDim2.new(0,20,0,20);box.Position=UDim2.new(1,-30,0.5,-10);box.BackgroundColor3=Color3.new(0.2,0.2,0.2);box.BorderSizePixel=1;box.BorderColor3=Color3.fromRGB(100,100,100)
    local chk=Instance.new("TextLabel",box);chk.Size=UDim2.new(1,0,1,0);chk.BackgroundTransparency=1;chk.Text="";chk.TextColor3=Color3.new(1,1,1);chk.RichText=true;chk.TextSize=18;chk.Font=Enum.Font.SourceSansBold
    
    b.MouseButton1Click:Connect(function() 
        local a = not (box.BackgroundColor3 == Color3.new(1,0,0))
        box.BackgroundColor3 = a and Color3.new(1,0,0) or Color3.new(0.2,0.2,0.2)
        chk.Text = a and "<b>✔</b>" or ""
        func(a)
    end)
    return b 
end

